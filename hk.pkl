amends "package://github.com/jdx/hk/releases/download/v1.46.0/hk@1.46.0#/Config.pkl"

min_hk_version = "1.46.0"

local linters = new Mapping<String, Step> {
  ["cargo-fmt"] {
    fix = "cargo fmt"
    check = "cargo fmt --check"
    glob = List("*.rs")
  }
  ["clippy"] {
    check = "cargo clippy -- -D warnings"
    glob = List("*.rs")
  }
  ["cargo-check"] {
    check = "cargo check"
    glob = List("*.rs")
  }
}

hooks {
  ["pre-commit"] {
    fix = true
    steps = linters
  }
  ["pre-push"] {
    steps = linters
  }
  ["fix"] {
    steps = linters
  }
  ["check"] {
    steps = linters
  }
}
